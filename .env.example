# VMS Docker 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=your_password_here
MYSQL_DATABASE=vmscloud

# ==================== 安全配置 ====================
JWT_SECRET=your_jwt_secret_here

# ==================== 文件上传 ====================
UPLOAD_PATH=/app/media
