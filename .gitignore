# 环境变量文件（包含敏感信息）
.env
# 但保留模板文件
!.env.example

# 数据目录
data/

# 日志目录
logs/

# 媒体文件（但保留默认图片）
media/
!media/images/
media/images/*
!media/images/default/

# IDE 和系统文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Node modules（前端构建时自动安装）
frontend/vedio-system/node_modules/

# Maven 构建产物
backend/VMS-springcloud/**/target/

# 软件测试文件夹
软件测试/

# 后端测试目录
backend/VMS-springcloud/**/src/test/

# 压缩包
*.zip
